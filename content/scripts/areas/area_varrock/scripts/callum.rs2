[opnpc1,callum]
~chatnpc("<p,happy>Welcome! I sell the finest skill capes and rare items.");
def_int $option = ~p_choice2("Let me take a look.", 1, "No thanks.", 2);
if($option = 1) {
    ~chatplayer("<p,happy>Let me take a look.");
    ~openshop_activenpc;
} else {
    ~chatplayer("<p,neutral>No thanks.");
}

[ai_queue3,callum]
npc_add(0_51_52_19_58, callum, 2000000);
